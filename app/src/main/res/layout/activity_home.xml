<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium">

        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/cinefast_red"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvSelectDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/select_date"
            android:textColor="@color/text_gray"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnToday"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/btn_primary"
                android:minWidth="100dp"
                android:paddingHorizontal="20dp"
                android:text="@string/today"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textAllCaps="false"/>

            <Button
                android:id="@+id/btnTomorrow"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/btn_outline"
                android:minWidth="100dp"
                android:paddingHorizontal="20dp"
                android:text="@string/tomorrow"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textAllCaps="false"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvNowShowing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/now_showing"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <!-- Movie 1: The Dark Knight -->
        <LinearLayout
            android:id="@+id/movieCard1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_background"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_medium">

            <ImageView
                android:id="@+id/moviePoster1"
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:background="@drawable/poster_dark_knight"
                android:contentDescription="The Dark Knight poster"
                android:scaleType="centerCrop"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/movieName1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="The Dark Knight"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/movieGenre1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Action / 152 min"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnBookSeats1"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/btn_primary"
                        android:minWidth="0dp"
                        android:paddingHorizontal="16dp"
                        android:text="@string/book_seats"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"/>

                    <Button
                        android:id="@+id/btnTrailer1"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/btn_outline"
                        android:minWidth="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="@string/trailer"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Movie 2: Inception -->
        <LinearLayout
            android:id="@+id/movieCard2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_background"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_medium">

            <ImageView
                android:id="@+id/moviePoster2"
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:background="@drawable/poster_inception"
                android:contentDescription="Inception poster"
                android:scaleType="centerCrop"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/movieName2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inception"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/movieGenre2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Sci-Fi / 148 min"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnBookSeats2"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/btn_primary"
                        android:minWidth="0dp"
                        android:paddingHorizontal="16dp"
                        android:text="@string/book_seats"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"/>

                    <Button
                        android:id="@+id/btnTrailer2"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/btn_outline"
                        android:minWidth="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="@string/trailer"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Movie 3: Interstellar -->
        <LinearLayout
            android:id="@+id/movieCard3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_background"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_medium">

            <ImageView
                android:id="@+id/moviePoster3"
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:background="@drawable/poster_interstellar"
                android:contentDescription="Interstellar poster"
                android:scaleType="centerCrop"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/movieName3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Interstellar"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/movieGenre3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Sci-Fi / 169 min"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnBookSeats3"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/btn_primary"
                        android:minWidth="0dp"
                        android:paddingHorizontal="16dp"
                        android:text="@string/book_seats"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"/>

                    <Button
                        android:id="@+id/btnTrailer3"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/btn_outline"
                        android:minWidth="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="@string/trailer"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Movie 4: The Shawshank Redemption -->
        <LinearLayout
            android:id="@+id/movieCard4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_background"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_medium">

            <ImageView
                android:id="@+id/moviePoster4"
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:background="@drawable/poster_shawshank"
                android:contentDescription="The Shawshank Redemption poster"
                android:scaleType="centerCrop"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/movieName4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="The Shawshank Redemption"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/movieGenre4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Drama / 142 min"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnBookSeats4"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/btn_primary"
                        android:minWidth="0dp"
                        android:paddingHorizontal="16dp"
                        android:text="@string/book_seats"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"/>

                    <Button
                        android:id="@+id/btnTrailer4"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/btn_outline"
                        android:minWidth="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="@string/trailer"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
