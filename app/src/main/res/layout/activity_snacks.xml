<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    android:padding="@dimen/spacing_medium">

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/cinefast_red"
        android:textSize="24sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tvSelectItems"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/select_items"
        android:textColor="@color/text_gray"
        android:textSize="14sp"/>

    <TextView
        android:id="@+id/tvSnacksHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/snacks_drinks"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Popcorn -->
            <LinearLayout
                android:id="@+id/snackCard1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_background"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_medium">

                <ImageView
                    android:id="@+id/snackImage1"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/snack_popcorn"
                    android:contentDescription="Popcorn"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/snackName1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Popcorn"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/snackDesc1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Large / Buttered"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btnMinus1"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/btn_outline"
                            android:text="-"
                            android:textColor="@color/white"
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/tvQty1"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="16sp"/>

                        <Button
                            android:id="@+id/btnPlus1"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/btn_primary"
                            android:text="+"
                            android:textColor="@color/white"
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/tvPrice1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="$8.99"
                            android:textColor="@color/white"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Nachos -->
            <LinearLayout
                android:id="@+id/snackCard2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_background"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_medium">

                <ImageView
                    android:id="@+id/snackImage2"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/snack_nachos"
                    android:contentDescription="Nachos"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/snackName2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nachos"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/snackDesc2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="With Cheese Dip"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btnMinus2"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/btn_outline"
                            android:text="-"
                            android:textColor="@color/white"
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/tvQty2"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="16sp"/>

                        <Button
                            android:id="@+id/btnPlus2"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/btn_primary"
                            android:text="+"
                            android:textColor="@color/white"
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/tvPrice2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="$7.99"
                            android:textColor="@color/white"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Soft Drink -->
            <LinearLayout
                android:id="@+id/snackCard3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_background"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_medium">

                <ImageView
                    android:id="@+id/snackImage3"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/snack_drink"
                    android:contentDescription="Soft Drink"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/snackName3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soft Drink"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/snackDesc3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medium / Coke"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btnMinus3"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/btn_outline"
                            android:text="-"
                            android:textColor="@color/white"
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/tvQty3"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="16sp"/>

                        <Button
                            android:id="@+id/btnPlus3"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/btn_primary"
                            android:text="+"
                            android:textColor="@color/white"
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/tvPrice3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="$4.99"
                            android:textColor="@color/white"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Candy Mix -->
            <LinearLayout
                android:id="@+id/snackCard4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/card_background"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_medium">

                <ImageView
                    android:id="@+id/snackImage4"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/snack_candy"
                    android:contentDescription="Candy Mix"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/snackName4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Candy Mix"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/snackDesc4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assorted"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btnMinus4"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/btn_outline"
                            android:text="-"
                            android:textColor="@color/white"
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/tvQty4"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="16sp"/>

                        <Button
                            android:id="@+id/btnPlus4"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/btn_primary"
                            android:text="+"
                            android:textColor="@color/white"
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/tvPrice4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="$5.99"
                            android:textColor="@color/white"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/tvSnackTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Snacks Total: $0.00"
        android:textColor="@color/white"
        android:textSize="16sp"/>

    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="16dp"
        android:background="@drawable/btn_primary"
        android:text="@string/confirm"
        android:textColor="@color/white"
        android:textAllCaps="false"/>
</LinearLayout>
